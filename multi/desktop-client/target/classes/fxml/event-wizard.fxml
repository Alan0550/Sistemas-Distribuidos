<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.upb.desktop.controller.EventWizardController"
      spacing="20" styleClass="screen-root">
    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <VBox spacing="4">
        <Label text="Crear nuevo evento" styleClass="title-label"/>
        <Label text="Completa los pasos para publicar un evento" styleClass="muted-label"/>
    </VBox>

    <VBox fx:id="stepOnePane" spacing="16" styleClass="card-panel">
        <Label text="PASO 1 - DATOS DEL EVENTO" styleClass="section-label"/>
        <Label text="Informacion general" styleClass="subtitle-label"/>

        <VBox spacing="6">
            <Label text="NOMBRE DEL EVENTO" styleClass="form-label"/>
            <TextField fx:id="eventNameField" promptText="Ej: Festival de Jazz 2026"
                       maxWidth="Infinity" styleClass="text-input"/>
        </VBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="FECHA" styleClass="form-label"/>
                <DatePicker fx:id="eventDatePicker" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="6">
                <Label text="HORA" styleClass="form-label"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Spinner fx:id="eventHourSpinner" prefWidth="80" styleClass="spinner"/>
                    <Label text=":" styleClass="muted-label"/>
                    <Spinner fx:id="eventMinuteSpinner" prefWidth="80" styleClass="spinner"/>
                </HBox>
            </VBox>
        </HBox>

        <VBox spacing="6">
            <Label text="CAPACIDAD TOTAL" styleClass="form-label"/>
            <Spinner fx:id="eventCapacitySpinner" prefWidth="160" styleClass="spinner"/>
        </VBox>

        <CheckBox fx:id="frequentDiscountCheckBox"
                  text="Habilitar descuento para usuarios frecuentes"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Cancelar" onAction="#onCancel" styleClass="secondary-button"/>
            <Button text="Siguiente ->" onAction="#onNextStep" styleClass="primary-button"/>
        </HBox>
    </VBox>

    <VBox fx:id="stepTwoPane" spacing="16" styleClass="card-panel">
        <Label text="PASO 2 - TIPOS DE ASIENTO" styleClass="section-label"/>
        <Label text="Configura los tipos y precios" styleClass="subtitle-label"/>

        <HBox spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="wizardSummaryLabel" text="Evento: -" styleClass="muted-label"/>
                <Label fx:id="remainingCapacityLabel" text="Capacidad restante por asignar: 0" styleClass="muted-label"/>
            </VBox>
        </HBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="seatTypeField" promptText="Tipo de asiento (Ej: VIP, General)"
                       HBox.hgrow="ALWAYS" styleClass="text-input"/>
            <Spinner fx:id="ticketTypeQuantitySpinner" prefWidth="110" styleClass="spinner"/>
            <TextField fx:id="ticketTypePriceField" promptText="Precio (Bs)"
                       prefWidth="120" styleClass="text-input"/>
            <Button text="+ Agregar" onAction="#onAddTicketType" styleClass="primary-button"/>
            <Button text="Quitar" onAction="#onRemoveTicketType" styleClass="secondary-button"/>
        </HBox>

        <TableView fx:id="ticketTypesTable" prefHeight="240">
            <columns>
                <TableColumn fx:id="seatTypeColumn" text="Tipo de asiento" prefWidth="240"/>
                <TableColumn fx:id="quantityColumn" text="Cantidad" prefWidth="120"/>
                <TableColumn fx:id="priceColumn" text="Precio (Bs)" prefWidth="120"/>
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Volver" onAction="#onBackStep" styleClass="secondary-button"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Cancelar" onAction="#onCancel" styleClass="secondary-button"/>
            <Button fx:id="finishButton" text="Guardar evento"
                    onAction="#onFinish" styleClass="primary-button"/>
        </HBox>
    </VBox>
</VBox>

