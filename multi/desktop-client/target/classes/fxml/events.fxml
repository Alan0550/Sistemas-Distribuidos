<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.upb.desktop.controller.EventsController"
      styleClass="screen-root">

    <HBox fx:id="adminShell" prefWidth="220" styleClass="nav-panel">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="24" right="12" bottom="24" left="12"/>
            </padding>

            <Label text="TickMaster" styleClass="brand-label">
                <VBox.margin><Insets bottom="4"/></VBox.margin>
            </Label>
            <Label fx:id="welcomeLabel" text="Panel Admin" styleClass="muted-label">
                <VBox.margin><Insets bottom="20"/></VBox.margin>
            </Label>

            <Button fx:id="dashboardNavButton" text="Monitoreo"
                    onAction="#onShowDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="eventsNavButton" text="Eventos"
                    onAction="#onShowAdminEvents" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="usersNavButton" text="Usuarios"
                    onAction="#onShowUsers" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="salesNavButton" text="Ventas"
                    onAction="#onShowSales" maxWidth="Infinity" styleClass="nav-button"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Cerrar sesion" onAction="#onLogout"
                    maxWidth="Infinity" styleClass="secondary-button"/>
        </VBox>
    </HBox>

    <VBox HBox.hgrow="ALWAYS" spacing="20">
        <padding>
            <Insets top="28" right="28" bottom="28" left="28"/>
        </padding>

        <VBox fx:id="dashboardPane" spacing="16" VBox.vgrow="ALWAYS">
            <Label text="Monitoreo operativo" styleClass="title-label"/>

            <HBox spacing="12">
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Estado general" styleClass="metric-label"/>
                    <Label fx:id="monitorStatusLabel" text="-" styleClass="metric-value"/>
                </VBox>
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Backends activos" styleClass="metric-label"/>
                    <Label fx:id="monitorBackendsLabel" text="-" styleClass="metric-value"/>
                </VBox>
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Errores acumulados" styleClass="metric-label"/>
                    <Label fx:id="monitorErrorsLabel" text="-" styleClass="metric-value"/>
                </VBox>
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Latencia promedio" styleClass="metric-label"/>
                    <Label fx:id="monitorLatencyLabel" text="-" styleClass="metric-value"/>
                </VBox>
            </HBox>

            <Label fx:id="monitorLastUpdateLabel" text="Actualizacion automatica: -" styleClass="muted-label"/>

            <TableView fx:id="backendTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="backendUrlColumn" text="Backend" prefWidth="220"/>
                    <TableColumn fx:id="backendStatusColumn" text="Estado" prefWidth="80"/>
                    <TableColumn fx:id="backendBalancingColumn" text="En balanceo" prefWidth="95"/>
                    <TableColumn fx:id="backendVerificationColumn" text="En verificacion" prefWidth="105"/>
                    <TableColumn fx:id="backendFailCountColumn" text="Fallos" prefWidth="75"/>
                    <TableColumn fx:id="backendDatabaseColumn" text="BD" prefWidth="60"/>
                    <TableColumn fx:id="backendDiskColumn" text="Disco" prefWidth="100"/>
                    <TableColumn fx:id="backendLastCheckColumn" text="Ultimo check" prefWidth="120"/>
                    <TableColumn fx:id="backendLastErrorColumn" text="Ultimo error" prefWidth="240"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="adminEventsPane" spacing="16" VBox.vgrow="ALWAYS" visible="false" managed="false">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Gestion de eventos" styleClass="title-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="adminEventFilterField" promptText="Buscar evento..."
                           prefWidth="220" styleClass="text-input"/>
                <Button fx:id="openEventWizardButton" text="+ Nuevo evento"
                        onAction="#onOpenEventWizard" styleClass="primary-button"/>
            </HBox>

            <Label fx:id="adminEventsSummaryLabel"
                   text="Selecciona un evento para ver su disponibilidad" styleClass="muted-label"/>

            <TableView fx:id="adminEventsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="adminEventIdColumn" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="adminEventNameColumn" text="Evento" prefWidth="260"/>
                    <TableColumn fx:id="adminEventDateColumn" text="Fecha" prefWidth="180"/>
                    <TableColumn fx:id="adminEventCapacityColumn" text="Capacidad" prefWidth="90"/>
                    <TableColumn fx:id="adminEventAvailableColumn" text="Disponibles" prefWidth="100"/>
                    <TableColumn fx:id="adminEventSoldColumn" text="Vendidos" prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="usersListPane" spacing="16" VBox.vgrow="ALWAYS" visible="false" managed="false">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Usuarios registrados" styleClass="title-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="userSearchField" promptText="Buscar por usuario o nombre..."
                           prefWidth="260" styleClass="text-input"/>
                <Button text="Actualizar" onAction="#onRefreshUsers" styleClass="secondary-button"/>
            </HBox>

            <HBox spacing="8">
                <Label fx:id="usersListSummaryLabel" text="Usuarios: 0 / 0" styleClass="muted-label"/>
                <Label text="- Doble click para ver historial" styleClass="muted-label"/>
            </HBox>

            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="userIdColumn" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="usernameColumn" text="Usuario" prefWidth="180"/>
                    <TableColumn fx:id="userNameColumn" text="Nombre" prefWidth="260"/>
                    <TableColumn fx:id="userRoleColumn" text="Rol" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="userHistoryPane" spacing="16" VBox.vgrow="ALWAYS" visible="false" managed="false">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="Volver" onAction="#onBackToUsers" styleClass="secondary-button"/>
                <Label fx:id="selectedUserLabel" text="Historial de compras" styleClass="title-label"/>
            </HBox>

            <Label fx:id="selectedUserMetaLabel"
                   text="Selecciona un usuario desde la lista" styleClass="muted-label"/>

            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="historyTicketIdColumn" text="Ticket" prefWidth="70"/>
                    <TableColumn fx:id="historyEventColumn" text="Evento" prefWidth="220"/>
                    <TableColumn fx:id="historyDateColumn" text="Fecha" prefWidth="170"/>
                    <TableColumn fx:id="historySeatTypeColumn" text="Tipo" prefWidth="120"/>
                    <TableColumn fx:id="historySeatColumn" text="Asiento" prefWidth="120"/>
                    <TableColumn fx:id="historyPriceColumn" text="Precio" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="salesPane" spacing="16" VBox.vgrow="ALWAYS" visible="false" managed="false">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Tickets y ventas" styleClass="title-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="salesSearchField" promptText="Buscar por ticket, usuario o evento..."
                           prefWidth="280" styleClass="text-input"/>
            </HBox>

            <HBox spacing="12">
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Tickets vendidos" styleClass="metric-label"/>
                    <Label fx:id="salesSummaryLabel" text="0" styleClass="metric-value"/>
                </VBox>
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Compradores unicos" styleClass="metric-label"/>
                    <Label fx:id="salesUsersLabel" text="0" styleClass="metric-value"/>
                </VBox>
                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                    <Label text="Ingresos estimados" styleClass="metric-label"/>
                    <Label fx:id="salesRevenueLabel" text="Bs 0.00" styleClass="metric-value"/>
                </VBox>
            </HBox>

            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="VENTAS POR EVENTO" styleClass="section-label"/>
                    <TableView fx:id="eventSalesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="eventSalesLabelColumn" text="Evento" prefWidth="240"/>
                            <TableColumn fx:id="eventSalesTicketsColumn" text="Tickets" prefWidth="90"/>
                            <TableColumn fx:id="eventSalesRevenueColumn" text="Ingresos" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="VENTAS POR TIPO DE ASIENTO" styleClass="section-label"/>
                    <TableView fx:id="seatTypeSalesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="seatSalesLabelColumn" text="Tipo" prefWidth="180"/>
                            <TableColumn fx:id="seatSalesTicketsColumn" text="Tickets" prefWidth="90"/>
                            <TableColumn fx:id="seatSalesRevenueColumn" text="Ingresos" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

            <Label text="COMPRAS REGISTRADAS" styleClass="section-label"/>
            <TableView fx:id="soldTicketsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="soldTicketIdColumn" text="Ticket" prefWidth="70"/>
                    <TableColumn fx:id="soldTicketUserColumn" text="Usuario" prefWidth="120"/>
                    <TableColumn fx:id="soldTicketNameColumn" text="Nombre" prefWidth="160"/>
                    <TableColumn fx:id="soldTicketEventColumn" text="Evento" prefWidth="190"/>
                    <TableColumn fx:id="soldTicketDateColumn" text="Fecha" prefWidth="150"/>
                    <TableColumn fx:id="soldTicketSeatTypeColumn" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="soldTicketSeatColumn" text="Asiento" prefWidth="100"/>
                    <TableColumn fx:id="soldTicketPriceColumn" text="Precio" prefWidth="90"/>
                </columns>
            </TableView>
        </VBox>

        <VBox fx:id="clientRoot" spacing="16" VBox.vgrow="ALWAYS" visible="false" managed="false">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4">
                    <Label text="Eventos disponibles" styleClass="title-label"/>
                    <Label fx:id="clientWelcomeLabel" text="Bienvenido" styleClass="muted-label"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Cerrar sesion" onAction="#onLogout" styleClass="secondary-button"/>
            </HBox>

            <TableView fx:id="clientEventsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="clientEventIdColumn" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="clientEventNameColumn" text="Evento" prefWidth="260"/>
                    <TableColumn fx:id="clientEventDateColumn" text="Fecha" prefWidth="200"/>
                    <TableColumn fx:id="clientEventCapacityColumn" text="Capacidad" prefWidth="110"/>
                </columns>
            </TableView>

            <VBox spacing="14" styleClass="card-panel">
                <Label text="Comprar tickets" styleClass="subtitle-label"/>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <ComboBox fx:id="ticketTypeCombo" promptText="Selecciona tipo de ticket"
                              HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Spinner fx:id="quantitySpinner" prefWidth="100" styleClass="spinner"/>
                    <Button text="Comprar" onAction="#onBuy" styleClass="primary-button"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</HBox>



