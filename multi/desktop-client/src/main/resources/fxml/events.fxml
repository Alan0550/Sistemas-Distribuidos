<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.upb.desktop.controller.EventsController"
      spacing="16" styleClass="screen-root">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label fx:id="welcomeLabel" text="Bienvenido" styleClass="title-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Cerrar sesion" onAction="#onLogout" styleClass="secondary-button"/>
    </HBox>

    <VBox fx:id="adminPanel" spacing="12">
        <HBox spacing="12">
            <VBox spacing="6" styleClass="card-panel" HBox.hgrow="ALWAYS">
                <Label text="Monitoreo en tiempo real" styleClass="subtitle-label"/>
                <Label fx:id="monitorStatusLabel" text="Estado sistema: -"/>
                <Label fx:id="monitorBackendsLabel" text="Backends activos: -"/>
                <Label fx:id="monitorErrorsLabel" text="Errores: -"/>
                <Label fx:id="monitorLastUpdateLabel" text="Actualizacion automatica: -"/>
            </VBox>
        </HBox>
    </VBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">
        <VBox spacing="12" HBox.hgrow="ALWAYS">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Eventos disponibles" styleClass="subtitle-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="openEventWizardButton" text="Nuevo evento" onAction="#onOpenEventWizard" styleClass="primary-button"/>
            </HBox>

            <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="nameColumn" text="Evento" prefWidth="220"/>
                    <TableColumn fx:id="dateColumn" text="Fecha" prefWidth="180"/>
                    <TableColumn fx:id="capacityColumn" text="Capacidad" prefWidth="100"/>
                </columns>
            </TableView>

            <VBox spacing="10" styleClass="card-panel" fx:id="purchasePanel">
                <Label text="Comprar tickets" styleClass="subtitle-label"/>
                <ComboBox fx:id="ticketTypeCombo" promptText="Selecciona tipo de ticket"/>
                <Spinner fx:id="quantitySpinner"/>
                <Button text="Comprar" onAction="#onBuy" styleClass="primary-button"/>
            </VBox>
        </VBox>

        <VBox fx:id="adminUsersPanel" spacing="12" prefWidth="430">
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Usuarios e historial" styleClass="subtitle-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Actualizar usuarios" onAction="#onRefreshUsers" styleClass="secondary-button"/>
            </HBox>

            <VBox spacing="10" styleClass="card-panel" VBox.vgrow="ALWAYS">
                <Label text="Usuarios registrados"/>
                <TableView fx:id="usersTable" prefHeight="200">
                    <columns>
                        <TableColumn fx:id="userIdColumn" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="usernameColumn" text="Username" prefWidth="110"/>
                        <TableColumn fx:id="userNameColumn" text="Nombre" prefWidth="160"/>
                        <TableColumn fx:id="userRoleColumn" text="Rol" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" styleClass="card-panel" VBox.vgrow="ALWAYS">
                <Label fx:id="selectedUserLabel" text="Historial de compras: sin seleccion"/>
                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="historyTicketIdColumn" text="Ticket" prefWidth="60"/>
                        <TableColumn fx:id="historyEventColumn" text="Evento" prefWidth="150"/>
                        <TableColumn fx:id="historyDateColumn" text="Fecha" prefWidth="140"/>
                        <TableColumn fx:id="historySeatTypeColumn" text="Tipo" prefWidth="90"/>
                        <TableColumn fx:id="historySeatColumn" text="Asiento" prefWidth="90"/>
                        <TableColumn fx:id="historyPriceColumn" text="Precio" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </HBox>
</VBox>
