<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.upb.desktop.controller.LoginController"
      alignment="CENTER" styleClass="screen-root">

    <!-- Card centrada -->
    <VBox alignment="TOP_LEFT" maxWidth="360" spacing="0" styleClass="auth-card">

        <!-- Marca -->
        <Label text="TickMaster" styleClass="brand-label"/>
        <Label text="Accede a tu cuenta" styleClass="muted-label">
            <VBox.margin><Insets top="4" bottom="28"/></VBox.margin>
        </Label>

        <!-- Campo: usuario -->
        <Label text="USUARIO" styleClass="form-label">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <TextField fx:id="usernameField" promptText="Ingresa tu usuario"
                   maxWidth="Infinity" styleClass="text-input">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </TextField>

        <!-- Campo: contraseña -->
        <Label text="CONTRASEÑA" styleClass="form-label">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField" promptText="Ingresa tu contraseña"
                       maxWidth="Infinity" styleClass="password-field">
            <VBox.margin><Insets bottom="24"/></VBox.margin>
        </PasswordField>

        <!-- Botones -->
        <Button text="Ingresar" onAction="#onLogin"
                maxWidth="Infinity" styleClass="primary-button">
            <VBox.margin><Insets bottom="10"/></VBox.margin>
        </Button>
        <Button text="Crear cuenta nueva" onAction="#onGoRegister"
                maxWidth="Infinity" styleClass="secondary-button"/>

    </VBox>

</VBox>
